{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "Order": 0,
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/Auth/{**catch-all}"
        }
      },
      "coach-profile-route": {
        "Order": 1,
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/api/CoachProfile/{**catch-all}"
        }
      },
      "trainee-profile-route": {
        "Order": 2,
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/api/TraineeProfile/{**catch-all}"
        }
      },
      "coach-certificate-route": {
        "Order": 3,
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/api/CoachCertificate/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-destination": {
            "Address": "http://localhost:5234"
          }
        }
      },
      "user-cluster": {
        "Destinations": {
          "user-destination": {
            "Address": "http://localhost:5284"
          }
        }
      }
    }
  }
}